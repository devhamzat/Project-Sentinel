# Keep the build context small and the image clean.
# The frontend build runs INSIDE the image, so we do want frontend/ source —
# but never its node_modules or a stale local dist.

# Data corpus (large; not needed at runtime — papers are ingested via the API)
data/

# Python
.venv/
venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node (rebuilt inside the image)
frontend/node_modules/
frontend/dist/

# Local dev / secrets / VCS
.env
.git/
.gitignore
docs/
tests/
# Note: README.md is intentionally NOT ignored — the Dockerfile copies it
# because pyproject.toml references it as the package readme.

# OS cruft
.DS_Store
Thumbs.db
