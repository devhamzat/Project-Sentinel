# Copy this file to .env and fill in your values.  Never commit .env.
# All config is read through smart_extract.config.settings — do not hardcode
# these values anywhere else in the code.

# ---------------------------------------------------------------------------
# Neo4j (graph database)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Authentication / deployment
# Generate AUTH_SECRET once, keep it private, and do not change it while users
# are signed in. Example: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Set AUTH_COOKIE_SECURE=true whenever the deployed site uses HTTPS.
# List only the exact frontend origins that may call this API.
# ---------------------------------------------------------------------------
AUTH_SECRET=replace-this-with-a-random-secret
AUTH_TOKEN_TTL_MINUTES=720
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_NAME=sentinel_session
REGISTRATION_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=25

# ---------------------------------------------------------------------------
# LLM seam (OpenAI-compatible endpoint — model-agnostic).
# Swap providers by changing ONLY these three values; no code changes.
#
# Option A — Groq (hosted, fast on CPU-only machines; recommended for dev):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_your_key_here
#   LLM_MODEL=llama-3.1-8b-instant
#
# Option B — Ollama (local, offline/privacy fallback; no API key needed):
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3.1
# ---------------------------------------------------------------------------
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# Embedding seam (SPIKE: semantic retrieval — see docs/design-retrieve.md).
# Separate from the chat seam because chat and embeddings often come from
# DIFFERENT providers (e.g. Groq serves chat but not embeddings). If left
# blank, these fall back to the LLM_* chat values above.
#
# OpenAI (chosen for the spike; text-embedding-3-small is dim 1536):
#   LLM_EMBED_BASE_URL=https://api.openai.com/v1
#   LLM_EMBED_API_KEY=sk_your_openai_key_here
#   LLM_EMBED_MODEL=text-embedding-3-small
#
# Local Ollama alternative (offline; nomic-embed-text is dim 768):
#   LLM_EMBED_BASE_URL=http://localhost:11434/v1
#   LLM_EMBED_API_KEY=ollama
#   LLM_EMBED_MODEL=nomic-embed-text
# ---------------------------------------------------------------------------
LLM_EMBED_BASE_URL=
LLM_EMBED_API_KEY=
LLM_EMBED_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# OCR engine (image/photo lane). Leave empty to use whatever is on PATH.
# On Windows the UB-Mannheim installer default is:
#   TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# The code auto-detects that default location, so you usually need not set this.
# ---------------------------------------------------------------------------
TESSERACT_CMD=

# ---------------------------------------------------------------------------
# Data directory (frozen corpus, gold set, etc.)
# ---------------------------------------------------------------------------
DATA_DIR=data
